//--- OBJECT WRITE END ---
function EWorldEditor::circularClone(%this, %count, %radius)
{
   if (%this.getSelectionSize() != 1)
   {
      echo("Select exactly ONE object.");
      return;
   }

   %this.addUndoState();

   %src = %this.getSelectedObject(0);
   %center = %src.getPosition();

   %cx = getWord(%center, 0);
   %cy = getWord(%center, 1);
   %cz = getWord(%center, 2);

   %step = 360 / %count;

   // Copy the source once
   %this.copySelection();

   for (%i = 0; %i < %count; %i++)
   {
      // Paste creates a REAL editor duplicate
      %this.pasteSelection();

      %clone = %this.getSelectedObject(0);

      %angle = %i * %step;
      %rad   = mDegToRad(%angle);

      %x = %cx + mCos(%rad) * %radius;
      %y = %cy + mSin(%rad) * %radius;

      %clone.setTransform(
         %x SPC %y SPC %cz SPC
         "0 0 1" SPC %angle
      );
   }
   %this.clearSelection();
   %this.selectObject(%src);
}
