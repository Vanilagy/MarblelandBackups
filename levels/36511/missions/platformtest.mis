         desc = "How good are you in Bounce control?";
         game = "Gold";
         gameMode = "null";
         generalHint = "1. Super Bounce hasn\'t perfect rebound, you still lose some height.\n2. This level contains parts where you have to artificially increase health to bounce higher from Super Bounce (e.g, doing wall-hit and then activate Super Bounce)\n3. If you collect powerup while holding powerup button, it activates instantly.";
         level = "1000";
         music = "Groove Police.ogg";
         name = "Absolute Recoil";
         platinumTime = "165000";
         startHelpText = "Go forward first!";
         trivia = "Name of this level has its good history: first name was \"MBG Platform\", that was made as I tested my Blender level, second name was \"Bounciness\", when I decided to do a Super Bounce-based level, third and current name, \"Absolute Recoil\", I came up with when I asked in Discord to suggest a cool name. Somebody suggested a name \"Really Radical Roundhouse Recoil Rush\", which was a little bit complicated. I came up with more simple and cool name, the current one. \n\nThanks for suggestions to improve my level to: spearmint, Kalle, Yoshicraft224";
         type = "Custom";
         ultimateHint = "You don\'t have to use first Super Speed and last two Super Bounces. The rest is about doing as little mistakes as you can and collecting all Time Travels";
         ultimateTime = "135000";
   };
